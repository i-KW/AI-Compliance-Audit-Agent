# GDPR Privacy Auditor — 环境变量配置
# 复制此文件为 .env 并填入你的 API key
# cp .env.example .env

# ═══════════════════════════════════════════════════════
# LLM 推理模型（审计 Agent / 仲裁 / DPIA 生成）
# ═══════════════════════════════════════════════════════

# 通义千问 DashScope API Key
# 获取地址: https://dashscope.console.aliyun.com/apiKey
OPENAI_API_KEY=sk-your-dashscope-key-here

# DashScope OpenAI 兼容端点
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型选择:
#   qwen-plus  (推荐) — 性能与成本平衡，适合 GDPR 审计
#   qwen-turbo  — 更快更便宜，适合简单任务
#   qwen-max   — 最强推理能力，适合复杂 DPIA
LLM_MODEL=qwen-plus

# 轻量模型（维度评分、路由判断等简单任务）
LLM_MODEL_LIGHT=qwen-turbo


# ═══════════════════════════════════════════════════════
# 嵌入模型（RAG 向量化 — 不影响文本生成）
# ═══════════════════════════════════════════════════════

# 默认复用 LLM 的 API Key。如果嵌入用不同服务，单独设置:
# EMBEDDING_API_KEY=sk-another-key
# EMBEDDING_BASE_URL=http://localhost:11434/v1

# 嵌入模型名
#   text-embedding-v3  — 通义千问（中文 ✅，维度可调）
#   bge-m3             — Ollama 本地（中文 ✅，1.2GB）
#   nomic-embed-text   — Ollama 本地（英文，137MB）
EMBEDDING_MODEL=text-embedding-v3

# 嵌入向量维度
#   text-embedding-v3: 1024（默认）/ 768 / 512
#   bge-m3:            1024
#   nomic-embed-text:  768
EMBEDDING_DIMENSION=1024


# ═══════════════════════════════════════════════════════
# LangGraph 配置（通常不需要改）
# ═══════════════════════════════════════════════════════

# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4096
# MAX_ITERATIONS=3
